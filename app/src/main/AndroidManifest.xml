<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- TV: declare we support leanback but don't require touchscreen -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KomsRooms"
        android:banner="@drawable/tv_banner">

        <!-- Discovery screen — the entry point for both phone and TV -->
        <activity
            android:name=".DiscoveryActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Manual connect / settings (also entry point if called directly) -->
        <activity
            android:name=".ConnectActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Mobile now-playing screen -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- TV / Chromecast now-playing screen -->
        <activity
            android:name=".TvActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Foreground service that keeps snapclient running -->
        <service
            android:name=".SnapclientService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>
