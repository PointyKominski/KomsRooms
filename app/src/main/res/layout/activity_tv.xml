<?xml version="1.0" encoding="utf-8"?>
<!--
    TV / Chromecast layout — landscape 16:9.
    Left 45%: album art.  Right 55%: info + controls.
    All buttons are focusable with visible focus rings for remote/D-pad navigation.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Album art — left side, square, vertically centred -->
    <ImageView
        android:id="@+id/ivAlbumArt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="Album art"
        android:layout_margin="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/divider"
        app:layout_constraintDimensionRatio="1:1" />

    <!-- Invisible divider at 45% width -->
    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.45" />

    <!-- Connection status strip — bottom of screen -->
    <LinearLayout
        android:id="@+id/statusStrip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#33000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Coloured dot: green = connected, red = disconnected -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@android:drawable/presence_online"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connecting…"
            android:textColor="@color/text_hint"
            android:textSize="13sp" />

        <!-- Stop/play audio toggle -->
        <TextView
            android:id="@+id/tvStopAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/tv_focus_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="16dp"
            android:paddingEnd="12dp" />

        <!-- Open currently playing track in Spotify app -->
        <TextView
            android:id="@+id/tvOpenSpotify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ Spotify"
            android:textColor="#1DB954"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/tv_focus_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="12dp" />

        <!-- Open web UI in browser -->
        <TextView
            android:id="@+id/tvOpenWebUi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 Web UI"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/tv_focus_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="12dp" />

        <!-- Tap to go back to server list -->
        <TextView
            android:id="@+id/tvChangeServer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change server"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/tv_focus_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Right panel — vertically centred -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingEnd="48dp"
        android:paddingStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Track title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spotify"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_marginBottom="8dp" />

        <!-- Artist -->
        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:textColor="@color/text_secondary"
            android:textSize="28sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="4dp" />

        <!-- Album -->
        <TextView
            android:id="@+id/tvAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="20sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="24dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/btn_bg"
            android:layout_marginBottom="8dp" />

        <!-- Time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_hint"
                android:textSize="16sp" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_hint"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Metallic transport strip — prev / play / pause / stop / next -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/metal_transport_bg">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_transport_prev"
                android:scaleType="center"
                android:background="@drawable/metal_btn_selector"
                android:focusable="true"
                android:contentDescription="Previous"
                android:nextFocusRight="@id/btnPlay"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnPlay"
                android:layout_width="76dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_transport_play"
                android:scaleType="center"
                android:background="@drawable/metal_btn_primary_selector"
                android:focusable="true"
                android:contentDescription="Play"
                android:nextFocusLeft="@id/btnPrev"
                android:nextFocusRight="@id/btnPause"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnPause"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_transport_pause"
                android:scaleType="center"
                android:background="@drawable/metal_btn_selector"
                android:focusable="true"
                android:contentDescription="Pause"
                android:nextFocusLeft="@id/btnPlay"
                android:nextFocusRight="@id/btnStop"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_transport_stop"
                android:scaleType="center"
                android:background="@drawable/metal_btn_selector"
                android:focusable="true"
                android:contentDescription="Stop"
                android:nextFocusLeft="@id/btnPause"
                android:nextFocusRight="@id/btnNext"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_transport_next"
                android:scaleType="center"
                android:background="@drawable/metal_btn_selector"
                android:focusable="true"
                android:contentDescription="Next"
                android:nextFocusLeft="@id/btnStop" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
