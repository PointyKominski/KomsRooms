<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KomsRoom"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Version label — tap 7 times to open dev panel -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v—"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pi IP Address"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.1.100"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="18sp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web UI Port"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etWebPort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5900"
                    android:inputType="number"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:padding="14dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Snapcast Port"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etSnapPort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1704"
                    android:inputType="number"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:padding="14dp"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- ═══ Hidden developer panel — revealed by 7-tapping the version label ═══ -->
        <LinearLayout
            android:id="@+id/devPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#1A8B5CF6"
            android:padding="16dp"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer Options"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/devBinaryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnUseStable"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Switch to stable"
                android:textSize="14sp"
                android:backgroundTint="#2A2A2A"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnUseCurrent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Switch to current"
                android:textSize="14sp"
                android:backgroundTint="#2A2A2A"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnPromoteToStable"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="How to promote current → stable"
                android:textSize="13sp"
                android:backgroundTint="#1A1A1A"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
